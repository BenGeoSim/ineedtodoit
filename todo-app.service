[Unit]
Description=Infinity ToDo FastAPI Server
After=network.target

[Service]
User=pi
Group=pi
WorkingDirectory=/home/pi/todo-app
Environment="PATH=/home/pi/todo-app/venv/bin"
ExecStart=/home/pi/todo-app/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
